{
    "exchange": "kucoin",
    "strategy": {
        "name": "KuCoin Futures L/S Crypto",
        "version": "1.0.0",
        "universe": "TOP100",
        "neutralization": "market",
        "combiner": "equal_weight",
        "max_position_weight": 0.10,
        "bars_per_day": 6,
        "rebalance_frequency": "4h"
    },
    "account": {
        "target_gmv": 100000,
        "leverage_limit": 2.0,
        "max_drawdown_halt_pct": 15.0
    },
    "execution": {
        "order_type": "TWAP",
        "twap_slices": 30,
        "min_order_value": 50,
        "taker_fee_bps": 1.5,
        "paper_mode": true,
        "_paper_note": "Paper mode simulates fills at last close. Set to false for live."
    },
    "kucoin": {
        "api_key_env": "KUCOIN_API_KEY",
        "api_secret_env": "KUCOIN_API_SECRET",
        "api_passphrase_env": "KUCOIN_API_PASSPHRASE",
        "base_url": "https://api-futures.kucoin.com"
    },
    "risk": {
        "max_single_position_pct": 3.0,
        "price_validation_tolerance_pct": 5.0,
        "max_daily_turnover_pct": 300.0,
        "stale_data_halt_hours": 12
    },
    "fees": {
        "model": "kucoin_vip12",
        "taker_bps": 1.5,
        "maker_bps": -0.5,
        "tick_slippage_multiplier": 1.0,
        "_note": "KuCoin VIP12: Taker 0.015%, Maker -0.005% (rebate)"
    },
    "paths": {
        "matrices": "data/kucoin_cache/matrices/4h/prod",
        "tick_sizes": "data/kucoin_cache/tick_sizes.json",
        "trade_logs": "prod/logs/kucoin/trades",
        "performance_logs": "prod/logs/kucoin/performance"
    },
    "alphas": [
        {"id": "A20", "expression": "zscore_cs(true_divide(sma(log_returns, 120), df_max(sma(parkinson_volatility_20, 120), 0.001)))", "weight": 1.0},
        {"id": "A21", "expression": "zscore_cs(sma(upper_shadow, 30))", "weight": 1.0},
        {"id": "A22", "expression": "zscore_cs(sma(ts_zscore(turnover, 240), 60))", "weight": 1.0},
        {"id": "A23", "expression": "Abs(momentum_20d)", "weight": 1.0},
        {"id": "A24", "expression": "ts_zscore(ts_sum(multiply(momentum_20d, returns), 180), 180)", "weight": 1.0},
        {"id": "A25", "expression": "add(ts_rank(low, 240), open_close_range)", "weight": 1.0},
        {"id": "A26", "expression": "df_min(ts_rank(adv20, 90), Decay_exp(square(momentum_5d), 36))", "weight": 1.0},
        {"id": "A27", "expression": "ts_zscore(rank(adv20), 240)", "weight": 1.0},
        {"id": "A28", "expression": "stddev(ts_sum(momentum_20d, 60), 6)", "weight": 1.0},
        {"id": "A29", "expression": "stddev(multiply(volume_momentum_5_20, momentum_20d), 18)", "weight": 1.0}
    ]
}
