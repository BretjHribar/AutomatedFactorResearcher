# Copy these values into your target-box .env or pass this file after .env.example.
# Do not commit real broker credentials.

IB_GATEWAY_IMAGE=ghcr.io/gnzsnz/ib-gateway:stable

# UAT: paper + port 4004 inside the Docker network.
# PROD: live + port 4003 inside the Docker network.
TRADING_MODE=paper
IB_GATEWAY_CONTAINER_API_PORT=4004
IB_HOST=ib-gateway
IB_PORT=4004

TWS_USERID=replace_me
TWS_PASSWORD=replace_me
# Prefer *_FILE on real cloud hosts when using Docker secrets or mounted secret files.
TWS_PASSWORD_FILE=

# Required only if TRADING_MODE=both.
TWS_USERID_PAPER=
TWS_PASSWORD_PAPER=
TWS_PASSWORD_PAPER_FILE=

TWS_SETTINGS_PATH=/home/ibgateway/tws_settings
TWS_ACCEPT_INCOMING=accept
READ_ONLY_API=no
TWOFA_TIMEOUT_ACTION=restart
TWOFA_EXIT_INTERVAL=180
TWOFA_DEVICE=
RELOGIN_AFTER_TWOFA_TIMEOUT=yes
EXISTING_SESSION_DETECTED_ACTION=primary
BYPASS_WARNING=yes
ALLOW_BLIND_TRADING=yes
AUTO_RESTART_TIME=11:45 PM
AUTO_LOGOFF_TIME=
TWS_COLD_RESTART=
SAVE_TWS_SETTINGS=
TIME_ZONE=America/New_York
JAVA_HEAP_SIZE=1024

# Host-local only; use SSH port-forwarding if you need remote VNC/API debugging.
IB_GATEWAY_BIND_ADDRESS=127.0.0.1
IB_GATEWAY_HOST_LIVE_PORT=4001
IB_GATEWAY_HOST_PAPER_PORT=4002
IB_GATEWAY_VNC_PORT=5900
VNC_SERVER_PASSWORD=

IB_GATEWAY_HEALTH_MODE=ib_insync
IB_GATEWAY_HEALTH_TIMEOUT_SEC=8
IB_CLIENT_ID_HEALTHCHECK=19
