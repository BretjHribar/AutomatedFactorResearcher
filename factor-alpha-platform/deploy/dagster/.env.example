FMP_API_KEY=replace_me
FACTOR_ALPHA_USER_CODE_IMAGE=factor_alpha_user_code:latest
FACTOR_ALPHA_DAGSTER_IMAGE=factor_alpha_dagster:latest
FACTOR_ALPHA_DATA_DIR=/opt/factor-alpha-platform/data
FACTOR_ALPHA_PROD_LOGS_DIR=/opt/factor-alpha-platform/prod/logs
# Local Docker Desktop -> Windows-hosted IB Gateway uses host.docker.internal:4002.
# Cloud docker-compose.ib-gateway.yml should override these to ib-gateway:4004 for UAT paper.
IB_HOST=host.docker.internal
IB_PORT=4002
IB_PASSWORD=
ENABLE_IB_LIVE_VWAP=0
ALLOW_IB_PAPER_ORDERS=0
FORCE_IB_PAPER_MOC=0
IB_PAPER_EXEC_TIMEOUT_SEC=1200
CRYPTO_PAPER_EXEC_TIMEOUT_SEC=900

DAGSTER_POSTGRES_USER=dagster
DAGSTER_POSTGRES_PASSWORD=dagster
DAGSTER_POSTGRES_DB=dagster
