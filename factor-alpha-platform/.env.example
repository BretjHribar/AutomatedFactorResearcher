# Factor Alpha Platform — Environment Variables
# Copy this to .env and fill in values. NEVER commit .env to git.

# Data vendor API keys (optional — platform works without them using synthetic data)
FMP_API_KEY=
EODHD_API_KEY=

# Database (defaults to SQLite for research mode)
DATABASE_URL=sqlite:///local.db

# Data directory (defaults to ./data)
DATA_DIR=./data

# Server
API_HOST=0.0.0.0
API_PORT=8000
